---
interface Props {
	title: string;
}
import '../styles/global.css';
const { title } = Astro.props;
---

<!doctype html>
<html lang="pt-br">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Notícias e análises do São Paulo FC" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="bg-spfc-black text-spfc-white">
		<!-- Header Futuro -->
		<main class="container mx-auto p-4">
			<slot />
		</main>
		<!-- Footer Futuro -->
	</body>
</html>
