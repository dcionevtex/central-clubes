---
interface Props {
	title: string;
}
import '@fontsource/playfair-display/400.css';
import '@fontsource/playfair-display/700.css';
import '@fontsource/playfair-display/900.css';
import '@fontsource/courier-prime';
import '../styles/global.css';

const { title } = Astro.props;
---

<!doctype html>
<html lang="pt-br" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="O diário oficial não-oficial do São Paulo FC." />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/escudo-spfc.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<!-- Fundo base quase preto, mas com um toque quente -->
	<body class="bg-[#0a0505] text-[#e0e0e0] font-['Courier_Prime'] antialiased selection:bg-spfc-red selection:text-white overflow-x-hidden">
		
		<!-- Borda Tricolor Lateral Esquerda (Moldura da Paixão) -->
		<div class="fixed top-0 left-0 h-full flex z-50">
			<div class="w-2 md:w-4 h-full bg-spfc-red shadow-[0_0_15px_rgba(226,0,26,0.5)]"></div>
			<div class="w-2 md:w-4 h-full bg-white"></div>
			<div class="w-2 md:w-4 h-full bg-black"></div>
		</div>

		<!-- Efeito de "Sinalizador" (Luz ambiente vermelha no topo) -->
		<div class="fixed top-0 left-0 w-full h-[500px] bg-gradient-to-b from-[#4a0000] to-transparent opacity-40 -z-10 pointer-events-none"></div>
		
		<main class="container mx-auto px-4 sm:px-6 lg:px-8 min-h-screen relative pl-12 md:pl-24 max-w-6xl">
			<slot />
		</main>
	</body>
</html>
