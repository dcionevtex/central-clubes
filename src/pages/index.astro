---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allNews = await getCollection('noticias');
const sortedNews = allNews.sort((a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf()).slice(0, 20);
---

<Layout title="Central SPFC">
	<!-- Faixa Tricolor Superior (Identidade Forte) -->
	<div class="fixed top-0 left-0 w-full z-50 shadow-lg">
		<div class="h-2 bg-spfc-red"></div>
		<div class="h-2 bg-spfc-white"></div>
		<div class="h-2 bg-spfc-black"></div>
	</div>

	<!-- Header com Escudo -->
	<div class="mt-16 mb-12 flex flex-col items-center justify-center animate-fade-in">
		<img src="/escudo-spfc.svg" alt="Escudo São Paulo FC" class="w-24 h-24 mb-4 drop-shadow-2xl" />
		<h1 class="text-5xl md:text-7xl font-black tracking-tighter uppercase text-center leading-none">
			<span class="text-spfc-red">Central</span>
			<span class="text-white">SPFC</span>
		</h1>
		<p class="text-gray-400 mt-2 font-medium tracking-wide uppercase text-sm md:text-base">
			Notícias • Análises • Paixão
		</p>
	</div>

	<!-- Grid de Notícias -->
	<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 pb-12">
		{sortedNews.map((news) => (
			<article class="group bg-neutral-900/50 border border-neutral-800 rounded-xl overflow-hidden hover:border-spfc-red hover:shadow-[0_0_20px_rgba(226,0,26,0.3)] transition-all duration-300 flex flex-col">
				<div class="p-6 flex flex-col h-full">
					<!-- Tag da Fonte -->
					<div class="flex items-center justify-between mb-3">
						<span class="px-2 py-1 bg-neutral-800 rounded text-[10px] font-bold text-spfc-red uppercase tracking-wider border border-neutral-700 group-hover:border-spfc-red/50 transition-colors">
							{news.data.source}
						</span>
						<time class="text-xs text-gray-500 font-mono" datetime={news.data.pubDate}>
							{new Date(news.data.pubDate).toLocaleDateString('pt-BR', { day: '2-digit', month: '2-digit' })}
						</time>
					</div>

					<!-- Título -->
					<h2 class="text-xl font-bold text-white leading-snug mb-3 group-hover:text-spfc-red transition-colors">
						<a href={news.data.link} target="_blank" rel="noopener noreferrer" class="block">
							{news.data.title}
						</a>
					</h2>

					<!-- Resumo -->
					<p class="text-gray-400 text-sm line-clamp-3 mb-4 flex-grow font-light leading-relaxed">
						{news.data.description}
					</p>

					<!-- Botão Ler Mais -->
					<div class="mt-auto pt-4 border-t border-neutral-800">
						<a href={news.data.link} target="_blank" rel="noopener noreferrer" class="inline-flex items-center text-xs font-bold text-white group-hover:translate-x-1 transition-transform uppercase tracking-widest">
							Ler Matéria <span class="ml-2 text-spfc-red">→</span>
						</a>
					</div>
				</div>
			</article>
		))}
	</div>
</Layout>
