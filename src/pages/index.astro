---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allNews = await getCollection('noticias');
const sortedNews = allNews.sort((a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf()).slice(0, 20);

// Separa a manchete principal das outras
const mainStory = sortedNews[0];
const otherStories = sortedNews.slice(1);
---

<Layout title="Central SPFC • O Diário">
	<!-- Cabeçalho do Jornal -->
	<header class="pt-12 pb-8 border-b-4 border-double border-white mb-12 flex flex-col items-center">
		<div class="flex items-center gap-6 mb-4">
			<img src="/escudo-spfc.svg" alt="Escudo São Paulo FC" class="w-16 h-16 opacity-80 grayscale hover:grayscale-0 transition-all duration-500" />
			<div class="text-center">
				<h1 class="font-['Playfair_Display'] text-6xl md:text-8xl font-black text-white tracking-tight uppercase leading-none">
					Central <span class="text-spfc-red">SPFC</span>
				</h1>
				<p class="font-['Courier_Prime'] text-sm tracking-[0.3em] uppercase text-gray-500 mt-2">Edição Diária • Est. 2026</p>
			</div>
			<img src="/escudo-spfc.svg" alt="Escudo São Paulo FC" class="w-16 h-16 opacity-80 grayscale hover:grayscale-0 transition-all duration-500" />
		</div>
		
		<div class="w-full flex justify-between border-t border-b border-[#333] py-2 mt-4 text-xs font-bold uppercase tracking-wider text-gray-400">
			<span>São Paulo, Brasil</span>
			<span>{new Date().toLocaleDateString('pt-BR', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' })}</span>
			<span>R$ 1,00</span>
		</div>
	</header>

	<!-- Manchete Principal (Capa) -->
	{mainStory && (
		<section class="mb-16 pb-12 border-b border-[#333]">
			<div class="flex flex-col md:flex-row gap-8">
				<div class="flex-1">
					<span class="inline-block border-b-2 border-spfc-red text-spfc-red font-bold uppercase text-xs mb-3 pb-1 tracking-widest">
						Destaque: {mainStory.data.source}
					</span>
					<h2 class="font-['Playfair_Display'] text-4xl md:text-6xl font-bold text-white leading-tight mb-6 hover:text-gray-300 transition-colors">
						<a href={mainStory.data.link} target="_blank" rel="noopener noreferrer">
							{mainStory.data.title}
						</a>
					</h2>
					<p class="text-xl text-gray-400 leading-relaxed font-light mb-6 border-l-4 border-spfc-red pl-4">
						{mainStory.data.description}
					</p>
					<a href={mainStory.data.link} target="_blank" rel="noopener noreferrer" class="inline-block bg-white text-black px-6 py-2 text-sm font-bold uppercase hover:bg-gray-200 transition-colors">
						Ler Matéria Completa
					</a>
				</div>
			</div>
		</section>
	)}

	<!-- Colunas de Notícias -->
	<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-12 pb-24">
		{otherStories.map((news) => (
			<article class="flex flex-col border-t border-[#333] pt-4">
				<span class="text-[10px] uppercase tracking-widest text-gray-500 mb-2 font-bold">
					{news.data.source} • {new Date(news.data.pubDate).toLocaleDateString('pt-BR', { day: '2-digit', month: '2-digit' })}
				</span>
				<h3 class="font-['Playfair_Display'] text-2xl font-bold text-white leading-tight mb-3 hover:text-spfc-red transition-colors">
					<a href={news.data.link} target="_blank" rel="noopener noreferrer">
						{news.data.title}
					</a>
				</h3>
				<p class="text-sm text-gray-400 leading-relaxed line-clamp-4">
					{news.data.description}
				</p>
			</article>
		))}
	</div>
</Layout>
